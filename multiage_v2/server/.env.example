# Copy this file to .env and fill in your values
# Never commit .env to git

PORT=5000
NODE_ENV=development

# MongoDB — get your URI from mongodb.com/atlas
MONGO_URI=
# Optional: comma-separated DNS servers for Node SRV lookup fallback
# MONGO_DNS_SERVERS=1.1.1.1,8.8.8.8

# Temporary password guard used by admin seeding and password-change validation
DEFAULT_TEMP_PASSWORD=

# JSON array of admin bootstrap entries, e.g. [{"name":"...","email":"...","role":"administrator","password":"..."}]
SEED_ADMINS_JSON=

# JWT — use a long random string (generate at: https://randomkeygen.com)
JWT_SECRET= 
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS) - set explicitly for your local or deployed client.
CLIENT_URL=https://multiage-v2-updated-1.vercel.app/

# Rate limiting (optional) — per IP, sliding 15-minute windows
# RATE_LIMIT_MAX=200
# RATE_LIMIT_AUTH_MAX=20

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email
EMAIL_USER=multiagetechnologies@gmail.com
EMAIL_PASS=
APP_NAME=Multiage Technologies
SUPPORT_EMAIL=multiagetechnologies@gmail.com
# Optional: absolute public logo URL for branded emails
EMAIL_LOGO_URL=

# Paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_CALLBACK_URL=
PAYSTACK_CURRENCY=GHS

# Firebase Admin (for backend verification of Google sign-in)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
