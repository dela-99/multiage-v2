# Copy this file to .env and fill in your values
# Never commit .env to git

PORT=5000
NODE_ENV=development

# MongoDB — get your URI from mongodb.com/atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/multiage?retryWrites=true&w=majority

# JWT — use a long random string (generate at: https://randomkeygen.com)
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Rate limiting (optional) — per IP, sliding 15-minute windows
# RATE_LIMIT_MAX=200
# RATE_LIMIT_AUTH_MAX=20

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email
EMAIL_PROVIDER=resend
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=Multiage Technologies <notifications@yourdomain.com>
ADMIN_EMAIL=admin@yourdomain.com
APP_NAME=Multiage Technologies

# Paystack
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PUBLIC_KEY=pk_test_...
PAYSTACK_CALLBACK_URL=http://localhost:5173/payment/callback
PAYSTACK_CURRENCY=GHS

# Firebase Admin (for backend verification of Google sign-in)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_service_account_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
