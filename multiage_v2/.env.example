# Required for production builds: base URL of the backend (do NOT include /api suffix).
# Example only: replace with your deployed backend URL before using in production.
# In local dev you may leave this unset — Vite proxies /api → your local backend.
VITE_API_BASE_URL=https://multiage-api.onrender.com

# Firebase configuration (required for Google sign-in).
# Add these to your Vercel project's Environment Variables.
# Find these values in your Firebase project settings → General → Your apps.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
